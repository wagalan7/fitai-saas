{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": { "cache": false },
    "db:studio": { "cache": false },
    "db:generate": { "outputs": ["node_modules/.prisma/**"] }
  }
}
