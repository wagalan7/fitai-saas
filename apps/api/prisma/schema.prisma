generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH & USERS ─────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  avatarUrl     String?
  role          Role     @default(USER)
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       UserProfile?
  sessions      Session[]
  onboarding    Onboarding?
  workoutPlans  WorkoutPlan[]
  workoutLogs   WorkoutLog[]
  nutritionPlan NutritionPlan?
  mealLogs      MealLog[]
  memories      Memory[]
  chatSessions  ChatSession[]
  progressLogs  ProgressLog[]
  subscription  Subscription?

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── USER PROFILE (onboarding data) ──────────────────────────────────────────

model UserProfile {
  id                 String         @id @default(cuid())
  userId             String         @unique
  // Mandatory profile fields
  cpf                String?
  phone              String?
  address            String?
  // Fitness profile
  age                Int            @default(0)
  weightKg           Float          @default(0)
  heightCm           Float          @default(0)
  genderIdentity     String?
  fitnessGoal        FitnessGoal    @default(GENERAL_FITNESS)
  fitnessLevel       FitnessLevel   @default(BEGINNER)
  workoutsPerWeek    Int            @default(3)
  workoutDuration    Int            @default(60)
  injuries           String[]
  dietaryRestrictions String[]
  foodPreferences    String[]
  availableEquipment String[]
  dailyRoutine       Json?
  updatedAt          DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

enum FitnessGoal {
  LOSE_WEIGHT
  GAIN_MUSCLE
  MAINTAIN
  IMPROVE_ENDURANCE
  IMPROVE_FLEXIBILITY
  GENERAL_FITNESS
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ATHLETE
}

// ─── ONBOARDING ───────────────────────────────────────────────────────────────

model Onboarding {
  id          String           @id @default(cuid())
  userId      String           @unique
  status      OnboardingStatus @default(IN_PROGRESS)
  currentStep Int              @default(0)
  answers     Json             @default("{}")
  completedAt DateTime?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboardings")
}

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

// ─── WORKOUTS ─────────────────────────────────────────────────────────────────

model WorkoutPlan {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  weekNumber  Int      @default(1)
  isActive    Boolean  @default(true)
  generatedBy String   @default("ai")
  rawPrompt   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions WorkoutSession[]

  @@map("workout_plans")
}

model WorkoutSession {
  id            String     @id @default(cuid())
  workoutPlanId String
  dayOfWeek     Int        // 0=Sun, 1=Mon, ...
  name          String
  muscleGroups  String[]
  estimatedTime Int        // minutes
  exercises     Exercise[]

  workoutPlan WorkoutPlan  @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  logs        WorkoutLog[]

  @@map("workout_sessions")
}

model Exercise {
  id               String         @id @default(cuid())
  workoutSessionId String
  order            Int
  name             String
  sets             Int
  reps             String         // "8-12" or "30s"
  restSeconds      Int
  notes            String?
  videoUrl         String?

  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)

  @@map("exercises")
}

model WorkoutLog {
  id               String         @id @default(cuid())
  userId           String
  workoutSessionId String
  completedAt      DateTime       @default(now())
  durationMinutes  Int?
  rating           Int?           // 1-5
  notes            String?
  exerciseLogs     ExerciseLog[]

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id])

  @@map("workout_logs")
}

model ExerciseLog {
  id           String     @id @default(cuid())
  workoutLogId String
  exerciseName String
  sets         SetLog[]
  notes        String?

  workoutLog WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)

  @@map("exercise_logs")
}

model SetLog {
  id            String      @id @default(cuid())
  exerciseLogId String
  setNumber     Int
  reps          Int?
  weightKg      Float?
  durationSecs  Int?
  rpe           Int?        // Rate of Perceived Exertion 1-10

  exerciseLog ExerciseLog @relation(fields: [exerciseLogId], references: [id], onDelete: Cascade)

  @@map("set_logs")
}

// ─── NUTRITION ────────────────────────────────────────────────────────────────

model NutritionPlan {
  id          String   @id @default(cuid())
  userId      String   @unique
  calories    Int
  proteinG    Float
  carbsG      Float
  fatG        Float
  isActive    Boolean  @default(true)
  generatedBy String   @default("ai")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals Meal[]

  @@map("nutrition_plans")
}

model Meal {
  id              String        @id @default(cuid())
  nutritionPlanId String
  name            String
  timeOfDay       String        // "breakfast", "lunch", "dinner", "snack"
  calories        Int
  proteinG        Float
  carbsG          Float
  fatG            Float
  foods           FoodItem[]

  nutritionPlan NutritionPlan @relation(fields: [nutritionPlanId], references: [id], onDelete: Cascade)

  @@map("meals")
}

model FoodItem {
  id       String @id @default(cuid())
  mealId   String
  name     String
  quantityG Float
  calories Int
  proteinG Float
  carbsG   Float
  fatG     Float
  alternatives String[]

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("food_items")
}

model MealLog {
  id         String   @id @default(cuid())
  userId     String
  mealName   String
  calories   Int
  proteinG   Float
  carbsG     Float
  fatG       Float
  loggedAt   DateTime @default(now())
  notes      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meal_logs")
}

// ─── MEMORY ───────────────────────────────────────────────────────────────────

model Memory {
  id        String      @id @default(cuid())
  userId    String
  agentType AgentType
  type      MemoryType
  content   String      @db.Text
  importance Float      @default(1.0)
  createdAt DateTime    @default(now())
  expiresAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, agentType])
  @@map("memories")
}

enum MemoryType {
  FACT        // "user has knee injury"
  PREFERENCE  // "user prefers mornings"
  PROGRESS    // "user added 5kg to squat"
  INSIGHT     // "user struggles with consistency"
  SUMMARY     // periodic conversation summary
}

enum AgentType {
  TRAINER
  NUTRITIONIST
  COACH
  ANALYST
  EVALUATOR
  SYSTEM
}

// ─── CHAT ─────────────────────────────────────────────────────────────────────

model ChatSession {
  id        String    @id @default(cuid())
  userId    String
  agentType AgentType
  title     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          MessageRole
  content       String      @db.Text
  agentType     AgentType?
  metadata      Json?
  createdAt     DateTime    @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ─── PROGRESS ─────────────────────────────────────────────────────────────────

model ProgressLog {
  id          String   @id @default(cuid())
  userId      String
  weightKg    Float?
  bodyFatPct  Float?
  muscleMassKg Float?
  chestCm     Float?
  waistCm     Float?
  hipCm       Float?
  armCm       Float?
  legCm       Float?
  photoUrl    String?
  notes       String?
  loggedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("progress_logs")
}

// ─── SUBSCRIPTION (SaaS) ──────────────────────────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  plan               SubscriptionPlan
  status             SubscriptionStatus
  stripeCustomerId   String?
  stripeSubId        String?
  currentPeriodEnd   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}
